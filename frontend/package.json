{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:verbose": "node scripts/dev-server.js --verbose",
    "dev:debug": "node scripts/dev-server.js --verbose --network",
    "dev:simple": "node scripts/dev-server.js",
    "build": "tsc -b && vite build",
    "build:gh-pages": "NODE_ENV=production vite build --mode production",
    "deploy:gh-pages": "npm run build:gh-pages && gh-pages -d dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:gh-pages": "vite preview --base=/nautobot-renderer/",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-query-devtools": "^5.87.4",
    "@types/dagre": "^0.7.53",
    "autoprefixer": "^10.4.21",
    "dagre": "^0.8.5",
    "elkjs": "^0.10.0",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "reactflow": "^11.11.4",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.3.3",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^5.0.0",
    "colors": "^1.4.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.1.1",
    "globals": "^16.3.0",
    "playwright-core": "^1.49.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^26.0.0",
    "msw": "^2.7.0",
    "ws": "^8.16.0"
  }
}
